# ============================================================
# .env.example — QuantMaster server 환경변수 템플릿
# ------------------------------------------------------------
# 이 파일을 `.env` 로 복사해서 본인 환경에 맞게 값을 채워 넣으세요.
# `.env` 는 .gitignore 로 커밋되지 않습니다.
#
# 사용 방법:
#   1) cp .env.example .env
#   2) 필요한 값 채우기
#   3) Spring 실행 시 환경변수로 주입 (PowerShell/bash 에서 export 후 ./mvnw spring-boot:run)
#
# 우선순위: 환경변수 > application-local.properties > application.properties 디폴트
# ============================================================

# --- Database ---
DB_URL=jdbc:mysql://localhost:3306/quant_db?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
DB_USER=root
DB_PASSWORD=CHANGE_ME

# --- Python 인터프리터 ---
# Windows: agent/venv/Scripts/python.exe (디폴트)
# Linux/Mac: agent/venv/bin/python
PYTHON_PATH=agent/venv/Scripts/python.exe
MANAGER_PYTHON=agent/AItr_manager/venv/Scripts/python.exe

# --- 스크립트 경로 (project root 기준 상대경로) ---
COLLECTOR_SCRIPT=agent/stock_collector.py
BACKTEST_SCRIPT=agent/backtest_runner.py
MANAGER_SCRIPT=agent/AItr_manager/main.py
SIMULATOR_SCRIPT=agent/pattern_match_service.py

# --- 기타 ---
COLLECTOR_ENABLED=false
MANAGER_TIMEOUT=720
SIMULATOR_TIMEOUT=60
